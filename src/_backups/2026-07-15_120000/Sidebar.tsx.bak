import { useState, useRef, useEffect } from 'react';
import { useNavigate } from 'react-router-dom';
import {
  LayoutDashboard,
  PieChart,
  TrendingUp,
  Bell,
  MessageSquareText,
  ChevronLeft,
  ChevronRight,
  Smartphone,
  Calendar,
  LogOut,
  User,
  ChevronDown,
  Check,
  Plus,
  Settings,
  Trash2,
} from 'lucide-react';
import AppSettingsModal, { type NewAppData } from './AppSettingsModal';
import ScrapeLoadingModal from './ScrapeLoadingModal';
import { type ScrapeRequest, type ReviewItem } from '../../api/scrapeApi';

interface SidebarProps {
  collapsed: boolean;
  onToggle: () => void;
  currentPath: string;
  onLogout: () => void;
}

interface AppItem {
  id: string;
  name: string;
  platform: string;
  icon: string;
  iosAppId?: string;
  androidPackageName?: string;
  country: string;
}

const navItems = [
  { id: '/dashboard', label: 'Overview', icon: LayoutDashboard },
  { id: '/segments', label: 'Segments', icon: PieChart },
  { id: '/predictions', label: 'Predictions', icon: TrendingUp },
  { id: '/alerts', label: 'Alerts', icon: Bell },
  { id: '/reviews', label: 'Reviews', icon: MessageSquareText },
];

function loadAppsFromStorage(): AppItem[] {
  try {
    const stored = localStorage.getItem('reviewpulse_apps');
    return stored ? JSON.parse(stored) : [];
  } catch {
    return [];
  }
}

const initialApps: AppItem[] = loadAppsFromStorage();

export default function Sidebar({ collapsed, onToggle, currentPath, onLogout }: SidebarProps) {
  const navigate = useNavigate();
  const [apps, setApps] = useState<AppItem[]>(initialApps);
  const [selectedApp, setSelectedApp] = useState<AppItem | null>(apps[0] ?? null);
  const [appDropdownOpen, setAppDropdownOpen] = useState(false);
  const [settingsOpen, setSettingsOpen] = useState(false);
  const [deleteConfirmId, setDeleteConfirmId] = useState<string | null>(null);
  const [dateRange, setDateRange] = useState('30d');
  const [showCustomDate, setShowCustomDate] = useState(false);
  const [customStartDate, setCustomStartDate] = useState('');
  const [customEndDate, setCustomEndDate] = useState('');
  const [accountOpen, setAccountOpen] = useState(false);
  
  // === TAMBAH: State untuk scraping ===
  const [scrapeModalOpen, setScrapeModalOpen] = useState(false);
  const [scrapeConfig, setScrapeConfig] = useState<ScrapeRequest | null>(null);
  
  const dropdownRef = useRef<HTMLDivElement>(null);
  const accountRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    const handler = (e: MouseEvent) => {
      if (dropdownRef.current && !dropdownRef.current.contains(e.target as Node)) {
        setAppDropdownOpen(false);
      }
      if (accountRef.current && !accountRef.current.contains(e.target as Node)) {
        setAccountOpen(false);
      }
    };
    document.addEventListener('mousedown', handler);
    return () => document.removeEventListener('mousedown', handler);
  }, []);

  useEffect(() => {
    if (!appDropdownOpen) setDeleteConfirmId(null);
  }, [appDropdownOpen]);

  const handleDateChange = (range: string) => {
    if (range === 'Custom') {
      setShowCustomDate(true);
      setDateRange('Custom');
    } else {
      setShowCustomDate(false);
      setDateRange(range);
    }
  };

  const openSettings = () => {
    setAppDropdownOpen(false);
    setSettingsOpen(true);
  };

  const handleAddApp = (data: NewAppData) => {
    const newApp: AppItem = {
      id: crypto.randomUUID(),
      name: data.name,
      platform: data.platform === 'both' ? 'iOS & Android' : data.platform === 'android' ? 'Android' : 'iOS',
      icon: data.name.slice(0, 2).toUpperCase(),
      iosAppId: data.iosAppId,
      androidPackageName: data.androidPackageName,
      country: data.country,
    };
    
    setApps((prev) => {
      const updated = [...prev, newApp];
      localStorage.setItem('reviewpulse_apps', JSON.stringify(updated));
      return updated;
    });
    
    setSelectedApp(newApp);
  };

  const handleDeleteApp = (id: string) => {
    setApps((prev) => {
      const appToDelete = prev.find((a) => a.id === id);
      
      if (appToDelete?.iosAppId) {
        localStorage.removeItem(`reviews_${appToDelete.iosAppId}`);
      }
      
      const updated = prev.filter((a) => a.id !== id);
      localStorage.setItem('reviewpulse_apps', JSON.stringify(updated));
      
      setSelectedApp((current) => (current?.id === id ? updated[0] ?? null : current));
      return updated;
    });
    setDeleteConfirmId(null);
  };

  // === TAMBAH: Handle scraping ===
  const handleScrape = (data: NewAppData) => {
    console.log('🔥 handleScrape called!', data);
    
    let app_id = '';
    if (data.platform === 'ios' || data.platform === 'both') {
      app_id = data.iosAppId;
    }
    
    if (!app_id) {
      alert('App ID iOS diperlukan untuk scraping');
      return;
    }

    setScrapeConfig({
      app_id,
      app_name: data.name,
      country: data.country,
      pages: 5,
    });
    setScrapeModalOpen(true);
  };

  const handleScrapeComplete = (reviews: ReviewItem[]) => {
    if (scrapeConfig) {
      localStorage.setItem(`reviews_${scrapeConfig.app_id}`, JSON.stringify(reviews));
      window.dispatchEvent(new CustomEvent('reviewpulse:data-updated'));
    }
    console.log('Reviews scraped:', reviews.length);
  };

  return (
    <>
      <aside
        className="h-screen flex flex-col overflow-hidden relative"
        style={{
          width: collapsed ? 64 : 260,
          backgroundColor: '#C62828',
          transition: 'width 300ms cubic-bezier(0.4, 0, 0.2, 1)',
        }}
      >
        {/* ... semua JSX yang sudah ada tetap sama ... */}
        
        {/* Brand Header */}
        <div className="flex items-center justify-between p-4 min-h-[64px] flex-shrink-0">
          {!collapsed && (
            <div className="flex items-center gap-2 text-white overflow-hidden">
              <Smartphone className="w-6 h-6 flex-shrink-0" />
              <span className="font-semibold text-lg tracking-tight whitespace-nowrap">ReviewPulse</span>
            </div>
          )}
          <button
            onClick={onToggle}
            className="p-1.5 rounded-lg hover:bg-white/10 transition-colors text-white flex-shrink-0"
          >
            {collapsed ? <ChevronRight className="w-5 h-5" /> : <ChevronLeft className="w-5 h-5" />}
          </button>
        </div>

        {/* Scrollable Content */}
        <div className="flex-1 overflow-y-auto scrollbar-thin min-h-0">
          {/* App Selector Dropdown */}
          {!collapsed && (
            <div className="px-4 mb-4 relative" ref={dropdownRef}>
              <label className="text-[10px] uppercase tracking-wider text-white/60 mb-1.5 block font-medium">
                Selected App
              </label>
              <button
                onClick={() => setAppDropdownOpen(!appDropdownOpen)}
                className="w-full flex items-center gap-2.5 bg-white/10 hover:bg-white/15 rounded-lg px-3 py-2.5 text-white transition-colors text-left"
              >
                {selectedApp ? (
                  <>
                    <div className="w-7 h-7 rounded-md bg-white/20 flex items-center justify-center flex-shrink-0">
                      <span className="text-[10px] font-bold">{selectedApp.icon}</span>
                    </div>
                    <div className="flex-1 min-w-0">
                      <div className="text-sm font-medium truncate">{selectedApp.name}</div>
                      <div className="text-[10px] text-white/60">{selectedApp.platform}</div>
                    </div>
                  </>
                ) : (
                  <div className="flex-1 min-w-0">
                    <div className="text-sm font-medium text-white/70">Belum ada app dipilih</div>
                    <div className="text-[10px] text-white/50">Klik untuk menambahkan</div>
                  </div>
                )}
                <ChevronDown className={`w-4 h-4 flex-shrink-0 transition-transform ${appDropdownOpen ? 'rotate-180' : ''}`} />
              </button>

              {/* Dropdown Menu */}
              {appDropdownOpen && (
                <div className="absolute left-4 right-4 top-full mt-1 bg-white rounded-xl shadow-xl border border-[#E8E0E0] z-50 overflow-hidden">
                  <div className="p-2">
                    <div className="text-[10px] uppercase tracking-wider text-[#9E8E8E] font-semibold px-2 py-1">
                      Your Apps
                    </div>

                    {apps.length === 0 ? (
                      <div className="px-2 py-4 text-center">
                        <p className="text-xs text-[#9E8E8E]">Belum ada aplikasi ditambahkan</p>
                      </div>
                    ) : (
                      apps.map((app) =>
                        deleteConfirmId === app.id ? (
                          <div
                            key={app.id}
                            className="flex items-center justify-between gap-2 px-2 py-2 bg-[#FFF3F3] rounded-lg"
                          >
                            <span className="text-xs text-[#C62828] font-medium truncate">
                              Hapus "{app.name}"?
                            </span>
                            <div className="flex items-center gap-1 flex-shrink-0">
                              <button
                                onClick={() => handleDeleteApp(app.id)}
                                className="text-[11px] font-semibold text-white bg-[#C62828] px-2 py-1 rounded-md hover:bg-[#8E0000] transition-colors"
                              >
                                Ya, Hapus
                              </button>
                              <button
                                onClick={() => setDeleteConfirmId(null)}
                                className="text-[11px] font-medium text-[#6B5B5B] px-2 py-1 rounded-md hover:bg-[#F0E8E8] transition-colors"
                              >
                                Batal
                              </button>
                            </div>
                          </div>
                        ) : (
                          <div
                            key={app.id}
                            className={`group flex items-center gap-1 rounded-lg transition-colors ${
                              selectedApp?.id === app.id ? 'bg-[#FFF8F7]' : 'hover:bg-gray-50'
                            }`}
                          >
                            <button
                              onClick={() => {
                                setSelectedApp(app);
                                setAppDropdownOpen(false);
                              }}
                              className="flex-1 flex items-center gap-2.5 px-2 py-2 text-left min-w-0"
                            >
                              <div
                                className="w-7 h-7 rounded-md flex items-center justify-center flex-shrink-0"
                                style={{
                                  backgroundColor: selectedApp?.id === app.id ? '#C62828' : '#F0E8E8',
                                }}
                              >
                                <span
                                  className="text-[10px] font-bold"
                                  style={{ color: selectedApp?.id === app.id ? 'white' : '#6B5B5B' }}
                                >
                                  {app.icon}
                                </span>
                              </div>
                              <div className="flex-1 text-left min-w-0">
                                <div className={`text-sm font-medium truncate ${selectedApp?.id === app.id ? 'text-[#C62828]' : 'text-[#2D1818]'}`}>
                                  {app.name}
                                </div>
                                <div className="text-[10px] text-[#9E8E8E]">{app.platform}</div>
                              </div>
                              {selectedApp?.id === app.id && <Check className="w-4 h-4 text-[#C62828] flex-shrink-0" />}
                            </button>
                            <button
                              onClick={() => setDeleteConfirmId(app.id)}
                              className="opacity-0 group-hover:opacity-100 p-1.5 mr-1 rounded-md text-[#9E8E8E] hover:text-[#C62828] hover:bg-[#FFCDD2]/50 transition-all flex-shrink-0"
                              title="Hapus aplikasi"
                            >
                              <Trash2 className="w-3.5 h-3.5" />
                            </button>
                          </div>
                        )
                      )
                    )}
                  </div>

                  <div className="border-t border-[#E8E0E0] p-2 space-y-0.5">
                    <button
                      onClick={openSettings}
                      className="w-full flex items-center gap-2 text-left px-2 py-1.5 text-xs text-[#C62828] font-medium hover:bg-[#FFF8F7] rounded-lg transition-colors"
                    >
                      <Plus className="w-3.5 h-3.5" />
                      Tambah Aplikasi Baru
                    </button>
                    <button
                      onClick={openSettings}
                      className="w-full flex items-center gap-2 text-left px-2 py-1.5 text-xs text-[#6B5B5B] font-medium hover:bg-[#FFF8F7] rounded-lg transition-colors"
                    >
                      <Settings className="w-3.5 h-3.5" />
                      Pengaturan
                    </button>
                  </div>
                </div>
              )}
            </div>
          )}

          {/* Date Range */}
          {!collapsed && (
            <div className="px-4 mb-4">
              <label className="text-[10px] uppercase tracking-wider text-white/60 mb-1.5 block font-medium">
                Date Range
              </label>
              <div className="grid grid-cols-2 gap-1">
                {['7d', '30d', '90d', 'Custom'].map((range) => (
                  <button
                    key={range}
                    onClick={() => handleDateChange(range)}
                    className={`text-xs py-1.5 px-2 rounded-md transition-all font-medium ${
                      dateRange === range
                        ? 'bg-white text-[#C62828]'
                        : 'bg-white/10 text-white/80 hover:bg-white/20'
                    }`}
                  >
                    {range === 'Custom' ? (
                      <span className="flex items-center justify-center gap-1">
                        <Calendar className="w-3 h-3" />
                        Custom
                      </span>
                    ) : (
                      `Last ${range}`
                    )}
                  </button>
                ))}
              </div>

              {showCustomDate && (
                <div className="mt-2 p-3 bg-white/10 rounded-lg space-y-2">
                  <div>
                    <label className="text-[10px] text-white/60 block mb-1">Start Date</label>
                    <input
                      type="date"
                      value={customStartDate}
                      onChange={(e) => setCustomStartDate(e.target.value)}
                      className="w-full px-2 py-1.5 rounded-md bg-white text-[#2D1818] text-xs focus:outline-none focus:ring-2 focus:ring-white/50"
                    />
                  </div>
                  <div>
                    <label className="text-[10px] text-white/60 block mb-1">End Date</label>
                    <input
                      type="date"
                      value={customEndDate}
                      onChange={(e) => setCustomEndDate(e.target.value)}
                      className="w-full px-2 py-1.5 rounded-md bg-white text-[#2D1818] text-xs focus:outline-none focus:ring-2 focus:ring-white/50"
                    />
                  </div>
                  <button
                    onClick={() => {
                      setShowCustomDate(false);
                      if (!customStartDate && !customEndDate) setDateRange('30d');
                    }}
                    className="w-full py-1.5 rounded-md bg-white text-[#C62828] text-xs font-semibold hover:bg-white/90 transition-colors"
                  >
                    Apply
                  </button>
                </div>
              )}
            </div>
          )}

          {/* Navigation */}
          <nav className="px-2 mb-4">
            {!collapsed && (
              <label className="text-[10px] uppercase tracking-wider text-white/60 mb-1.5 px-2 block font-medium">
                Navigation
              </label>
            )}
            {navItems.map((item) => {
              const Icon = item.icon;
              const isActive = currentPath === item.id;
              return (
                <button
                  key={item.id}
                  onClick={() => navigate(item.id)}
                  className={`w-full flex items-center gap-3 px-3 py-2.5 rounded-lg transition-all duration-200 mb-0.5 ${
                    isActive
                      ? 'bg-white text-[#C62828] shadow-sm'
                      : 'text-white/80 hover:bg-white/10 hover:text-white'
                  }`}
                  title={collapsed ? item.label : undefined}
                >
                  <Icon className="w-[18px] h-[18px] flex-shrink-0" />
                  {!collapsed && <span className="text-sm font-medium">{item.label}</span>}
                </button>
              );
            })}
          </nav>
        </div>

        {/* Account Section */}
        {!collapsed && (
          <div className="flex-shrink-0 p-4 border-t border-white/10" ref={accountRef}>
            <button
              onClick={() => setAccountOpen(!accountOpen)}
              className="w-full flex items-center gap-3 hover:bg-white/10 rounded-lg p-2 transition-colors"
            >
              <div className="w-9 h-9 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
                <User className="w-4 h-4 text-white" />
              </div>
              <div className="flex-1 text-left min-w-0">
                <div className="text-sm font-medium text-white truncate">Admin User</div>
                <div className="text-[10px] text-white/60">admin@reviewpulse.io</div>
              </div>
              <ChevronDown className={`w-4 h-4 text-white/60 flex-shrink-0 transition-transform ${accountOpen ? 'rotate-180' : ''}`} />
            </button>

            {accountOpen && (
              <div className="mt-2 bg-white/10 rounded-lg overflow-hidden">
                <button
                  onClick={() => setAccountOpen(false)}
                  className="w-full flex items-center gap-2 px-3 py-2 text-sm text-white/80 hover:bg-white/10 transition-colors"
                >
                  <User className="w-4 h-4" />
                  Account Settings
                </button>
                <button
                  onClick={() => {
                    setAccountOpen(false);
                    onLogout();
                  }}
                  className="w-full flex items-center gap-2 px-3 py-2 text-sm text-white/80 hover:bg-white/10 transition-colors"
                >
                  <LogOut className="w-4 h-4" />
                  Sign Out
                </button>
              </div>
            )}
          </div>
        )}

        {/* Collapsed Account Icon */}
        {collapsed && (
          <div className="flex-shrink-0 p-3 border-t border-white/10 flex justify-center">
            <button
              onClick={onLogout}
              className="p-2 rounded-lg hover:bg-white/10 text-white/60 hover:text-white transition-colors"
              title="Sign Out"
            >
              <LogOut className="w-5 h-5" />
            </button>
          </div>
        )}
      </aside>

      {/* Modal Tambah Aplikasi */}
      <AppSettingsModal
        isOpen={settingsOpen}
        onClose={() => setSettingsOpen(false)}
        onSave={handleAddApp}
        onScrape={handleScrape}  // ← TAMBAH INI
      />

      {/* Loading Modal Scraping */}
      <ScrapeLoadingModal
        isOpen={scrapeModalOpen}
        onClose={() => setScrapeModalOpen(false)}
        scrapeConfig={scrapeConfig}
        onScrapeComplete={handleScrapeComplete}
      />
    </>
  );
}
